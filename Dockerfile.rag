FROM python:3.12-slim
RUN pip install --no-cache-dir fastapi uvicorn qdrant-client httpx redis kafka-python "langfuse>=2.0,<3.0" minio prometheus-client \
    opentelemetry-api opentelemetry-sdk opentelemetry-instrumentation-fastapi opentelemetry-instrumentation-httpx opentelemetry-exporter-otlp-proto-grpc
COPY 06-rag-code.py /app/main.py
COPY qdrant_snapshots.py /app/qdrant_snapshots.py
COPY kafka_config.py /app/kafka_config.py
WORKDIR /app
CMD ["python", "/app/main.py"]
